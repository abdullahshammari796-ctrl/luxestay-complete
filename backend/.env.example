# LuxeStay Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/luxestay
# For MongoDB Atlas use:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/luxestay

# JWT Secret (use a long random string in production)
JWT_SECRET=luxestay_super_secret_jwt_key_2025_change_in_production
JWT_EXPIRE=30d

# Admin Seed Credentials
ADMIN_EMAIL=admin@luxestay.com
ADMIN_PASSWORD=admin123
